 (name main)
 (modules main)
 (libraries retargeting retargeting_gen))

; The paper-table measurement harness (tab:impl-measure): the base analyzer
; vs. the stored specialized analyzer (summary / denotations) on the native
; benchmark suite. Standalone, NOT wired into `dune test`; run via
; scripts/reproduce-table.sh or `dune exec bin/bench_paper.exe`.
(executable
 (name bench_paper)
 (modules bench_paper)
 (libraries retargeting retargeting_gen unix))

; Aggregates bench_paper replicate TSVs into the paper table (per-cell
; median of replicate medians, speedups, geometric means).
(executable
 (name paper_table)
 (modules paper_table))

; Prints the rule set the specializer derives from the interpreter text -- the
; paper's factorization table -- and the per-frame context bindings beside it.
; Standalone; run via `dune exec bin/calc_rules.exe`.
(executable
 (name calc_rules)
 (modules calc_rules)
 (libraries retargeting))
